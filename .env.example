# Supabase Environment Variables
# Get these values from your Supabase project dashboard

# Your application's base URL (required for OAuth redirects)
# Local development: http://localhost:3004 (or your port)
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Your Supabase Project URL
# Found in: Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anon Public Key
# Found in: Settings > API > Project API keys > anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase Service Role Key (do NOT expose in frontend!)
# Only use this in server-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Configuration
NEXT_PUBLIC_GGHUB_ADMIN_EMAILS=admin@example.com

# Netlify Build Hook (for redeploy functionality)
# Found in: Site Settings > Build & Deploy > Build Hooks
NEXT_PUBLIC_NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your_build_hook_id
